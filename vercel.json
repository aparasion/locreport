{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/monthly-report",
      "schedule": "0 3 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/reports/2026-Annual-Global-Market-Report",
      "destination": "/reports/2026-annual-global-market-report",
      "permanent": true
    },
    {
      "source": "/reports/2026-Annual-Global-Market-Report/",
      "destination": "/reports/2026-annual-global-market-report",
      "permanent": true
    },
    {
      "source": "/articles/:year/:month/:day/:slug.html",
      "destination": "/articles/:slug",
      "permanent": true
    },
    {
      "source": "/all-articles",
      "destination": "/articles",
      "permanent": true
    },
    {
      "source": "/all-articles/",
      "destination": "/articles",
      "permanent": true
    },
    {
      "source": "/research",
      "destination": "/language-science",
      "permanent": true
    },
    {
      "source": "/research/",
      "destination": "/language-science",
      "permanent": true
    }
  ]
}
