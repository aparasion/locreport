{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "redirects": [
    { "source": "/market", "destination": "/compass/locstock", "permanent": true },
    { "source": "/market/", "destination": "/compass/locstock", "permanent": true },
    { "source": "/events", "destination": "/compass/events", "permanent": true },
    { "source": "/events/", "destination": "/compass/events", "permanent": true },
    { "source": "/tools/llm-pricing", "destination": "/compass/llm-pricing", "permanent": true },
    { "source": "/tools/llm-pricing/", "destination": "/compass/llm-pricing", "permanent": true },
    { "source": "/tools/directory", "destination": "/compass/directory", "permanent": true },
    { "source": "/tools/directory/", "destination": "/compass/directory", "permanent": true },
    {
      "source": "/reports/2026-Annual-Global-Market-Report",
      "destination": "/reports/2026-annual-global-market-report",
      "permanent": true
    },
    {
      "source": "/reports/2026-Annual-Global-Market-Report/",
      "destination": "/reports/2026-annual-global-market-report",
      "permanent": true
    },
    {
      "source": "/articles/:year/:month/:day/:slug.html",
      "destination": "/articles/:slug",
      "permanent": true
    },
    {
      "source": "/all-articles",
      "destination": "/articles",
      "permanent": true
    },
    {
      "source": "/all-articles/",
      "destination": "/articles",
      "permanent": true
    },
    {
      "source": "/research",
      "destination": "/language-science",
      "permanent": true
    },
    {
      "source": "/research/",
      "destination": "/language-science",
      "permanent": true
    }
  ]
}
