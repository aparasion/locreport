---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
    {% if page.url contains '.xml' or page.url contains '.txt' %}
      {% continue %}
    {% endif %}
    {% if page.layout %}
    <url>
      <loc>{{ page.url | replace:'index.html','' | absolute_url }}</loc>
      <lastmod>{{ page.last_modified_at | default: page.date | default: site.time | date_to_xmlschema }}</lastmod>
      <changefreq>weekly</changefreq>
      <priority>{% if page.url == '/' %}1.0{% elsif page.url == '/intelligence/' or page.url == '/topics/' or page.url == '/signals/' %}0.9{% elsif page.topic or page.url == '/all-articles/' or page.url == '/monthly-reports/' %}0.8{% elsif page.url == '/about/' or page.url == '/contact/' or page.url == '/newsletter/' or page.url == '/search/' %}0.6{% elsif page.url == '/privacy/' or page.url == '/terms/' %}0.3{% else %}0.7{% endif %}</priority>
    </url>
    {% endif %}
  {% endfor %}

  {% for post in site.posts %}
    <url>
      <loc>{{ post.url | replace:'index.html','' | absolute_url }}</loc>
      <lastmod>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</lastmod>
      <changefreq>daily</changefreq>
      <priority>{% if post.impact_score >= 4 %}0.9{% elsif post.impact_score >= 3 %}0.8{% else %}0.7{% endif %}</priority>
    </url>
  {% endfor %}
</urlset>
